OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# Optional: point at an OpenAI-compatible endpoint (e.g. internal gateway, Azure, vLLM)
# OPENAI_BASE_URL=https://your-gateway.example.com/v1/
REDIS_URL=redis://localhost:6379
BACKEND_URL=http://localhost:4000
WORKER_CONCURRENCY=3
AGENT_MAX_STEPS=5
# Higher cap for `code` tasks since real coding loops need many tool calls.
AGENT_MAX_STEPS_CODE=50
# Per-step timeout. Resets on each step finish, so the total run can be
# up to AGENT_MAX_STEPS * AGENT_TIMEOUT_MS in the worst case.
AGENT_TIMEOUT_MS=60000
NODE_ENV=development

# macOS MCP tools (Notes / Calendar / Reminders / Mail / Messages / Contacts).
# When ENABLE_MAC_TOOLS=true, the worker spawns mcp-macos over stdio at boot
# and exposes its tools to the agent ONLY for tasks whose type matches
# MAC_TOOLS_TASK_TYPE. Requires the appropriate macOS Privacy permissions.
ENABLE_MAC_TOOLS=true
MAC_TOOLS_TASK_TYPE=mac_action

# Coding-harness MCP tools (filesystem + git, scoped to CODE_WORKSPACE_DIR).
# When ENABLE_CODE_TOOLS=true, the worker spawns:
#   - @modelcontextprotocol/server-filesystem (scoped to CODE_WORKSPACE_DIR)
#   - @cyanheads/git-mcp-server (scoped via --repo-path CODE_WORKSPACE_DIR)
# and exposes their tools to the agent ONLY for tasks whose type matches
# CODE_TASK_TYPE. WARNING: with WORKER_CONCURRENCY>1 multiple coding tasks
# will race on the same workspace; consider lowering concurrency or moving
# to a worktree-per-task model.
ENABLE_CODE_TOOLS=false
CODE_TASK_TYPE=code
# CODE_WORKSPACE_DIR=/absolute/path/to/repo
